<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Local Markdown viewer; not distributed via the App Store.
        App sandbox is intentionally disabled so the preview can read
        sibling assets next to the opened .md file (e.g. 附图/*.svg,
        local CSS, included images). Re-enabling the sandbox requires
        switching to NSDocument/folder-scoped bookmarks for image access.
    -->
</dict>
</plist>
